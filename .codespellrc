# Codespell configuration — single source of truth for CI (.github/workflows/codespell.yml)
# and local runs (`codespell` from the repo root).
[codespell]
# *.min.js: generated minified bundles (demo/fluxum.min.js is copied out of
# the TS build); minifier-mangled identifiers are not prose.
skip = *.lock,*.json,*.map,*.yaml,*.yml,*.csv,*.bib,*.min.js,target,node_modules,.git,dist,venv,build,benchmarks,coverage
# Proper nouns and intentional terms:
#   UE (Unreal Engine), Dota (the game), retuned/retune (hardware re-tuning, SPEC-016),
#   implementors (verbatim quote from SpacetimeDB source), statics (Rust plural of
#   `static` items), FluxBIN/BSATN/SATS/UzDB/msgpack (format names), plus the rulebook
#   defaults (crate, ser, deser, ...).
#   Intentional terms flagged as typos:
#     keep-alives (valid plural, RPC-001), unparseable (valid variant),
#     lits (SQL AST literals), caf (from the "Café" Unicode-normalization test),
#     runn (Porter-stemmer output for "running", not a typo),
#     atLeast (camelCase identifier in the conformance interpreter).
ignore-words-list = crate,ser,deser,upToDate,optIn,shouldBe,Bloc,UE,ue,Dota,dota,retuned,implementors,statics,FluxBIN,fluxbin,BSATN,bsatn,SATS,sats,UzDB,uzdb,msgpack,keep-alives,unparseable,lits,caf,runn,atLeast
