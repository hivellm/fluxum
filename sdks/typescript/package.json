{
  "name": "@hivehub/fluxum",
  "version": "0.1.0",
  "description": "Fluxum realtime database client — typed bindings over the HiveLLM binary wire (Thunder)",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hivellm/fluxum.git",
    "directory": "sdks/typescript"
  },
  "scripts": {
    "build": "node build.mjs",
    "test": "node --test \"tests/*.test.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@hivehub/thunder": "^0.2.1",
    "@msgpack/msgpack": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "esbuild": "^0.28.1",
    "typescript": "^5"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./browser": "./dist/fluxum.min.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false
}
